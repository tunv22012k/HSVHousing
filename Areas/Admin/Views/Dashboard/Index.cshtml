@{
    ViewBag.Title = "Tổng quan";
}

<div class="container-fluid mt-3">
    <h2 class="mb-4">Tổng quan hệ thống</h2>
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-primary h-100">
                <div class="card-body">
                    <h5 class="card-title">Người dùng (Sinh viên)</h5>
                    <h2 class="display-5">@ViewBag.TotalUsers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-success h-100">
                <div class="card-body">
                    <h5 class="card-title">Chủ trọ</h5>
                    <h2 class="display-5">@ViewBag.TotalLandlords</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-warning h-100 text-dark">
                <div class="card-body">
                    <h5 class="card-title">Tin chờ duyệt</h5>
                    <h2 class="display-5">@ViewBag.PendingListings</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-info h-100 text-dark">
                <div class="card-body">
                    <h5 class="card-title">Tin đang hoạt động</h5>
                    <h2 class="display-5">@ViewBag.ActiveListings</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-secondary h-100">
                <div class="card-body">
                    <h5 class="card-title">Tổng lượt xem tin</h5>
                    <h2 class="display-5">@ViewBag.TotalViews</h2>
                </div>
            </div>
        </div>
    </div>
</div>
